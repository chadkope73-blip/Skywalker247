  "polarisGuidance": {
    "northernHemisphereOnly": true,
    "method": "Use Dubhe and Merak in Ursa Major to point toward Polaris. Cassiopeia provides supporting north-side reference.",
    "latitudeRule": "Approximate observer latitude is close to Polaris altitude above horizon in the northern hemisphere."
  },
  "solveModes": {
    "timeFromSky": {
      "description": "Use known location plus observed sky reference to estimate time.",
      "requiredInputs": ["date", "latitude", "longitude"],
      "optionalInputs": ["zip"],
      "outputs": ["skyTimeEstimate", "constellationMatch", "polarisLock", "solveConfidence"]
    },
    "locationFromSky": {
      "description": "Use known time plus observed sky reference to estimate approximate latitude/longitude band.",
      "requiredInputs": ["date", "knownTime"],
      "optionalInputs": ["referenceConstellation"],
      "outputs": ["estimatedLocation", "constellationMatch", "polarisLock", "solveConfidence"]
    },
    "referenceOnly": {
      "description": "Use the sky as a celestial reference for north and constellation identification.",
      "requiredInputs": [],
      "optionalInputs": ["date"],
      "outputs": ["celestialNorth", "constellationMatch", "solveConfidence"]
    }
  }
